# Copy to .env and edit before: docker compose --env-file .env up --build

POSTGRES_USER=kongmanager
POSTGRES_PASSWORD=change-me-db
POSTGRES_DB=kong_manager

JWT_SECRET=change-me-long-random-string
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin

KONG_MANAGER_PORT=8080

# Kong Admin URL reachable from the BFF container (Docker Desktop: host.docker.internal)
KONG_ADMIN_URL=http://host.docker.internal:8001

PUBLIC_BASE_URL=
COOKIE_SECURE=false
